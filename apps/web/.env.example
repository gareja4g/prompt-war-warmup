# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mindwell?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o"

# Google AI (optional fallback)
GOOGLE_GENERATIVE_AI_API_KEY="your-google-ai-api-key"

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Sentry
SENTRY_DSN="https://your-sentry-dsn"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn"
SENTRY_ORG="your-org"
SENTRY_PROJECT="mindwell"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# Resend (email)
RESEND_API_KEY="re_your-resend-api-key"
RESEND_FROM_EMAIL="noreply@mindwell.app"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="MindWell"

# Encryption
ENCRYPTION_KEY="your-32-char-encryption-key-here"

# Feature flags
NEXT_PUBLIC_ENABLE_CRISIS_SUPPORT="true"
NEXT_PUBLIC_ENABLE_GAMIFICATION="true"
